<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MediAgenda - Control de Citas</title>
    <link rel="stylesheet" href="css/style.css">

</head>
<body>
    <header>
        <h1>Bienvenido a MediAgenda</h1>
        <p>El sistema inteligente para gestionar tus citas médicas.</p>
    </header>
    <main>
        <section class="form-container">
    <h2>Registrar Nuevo Paciente</h2>
    <form id="patient-form">
        <div class="form-group">
            <label for="nombre">Nombre Completo:</label>
            <input type="text" id="nombre" required placeholder="Ej. Juan Pérez">
        </div>
        <div class="form-group">
            <label for="fecha">Fecha de la Cita:</label>
            <input type="date" id="fecha" required>
        </div>
        <div class="form-group">
            <label for="hora">Hora de la Cita:</label>
            <input type="time" id="hora" required>
        </div>
        <button type="submit">Agendar Cita</button>
    </form>
</section>
<section class="table-container">
    <h2>Citas Programadas</h2>
    <table id="appointments-table">
        <thead>
            <tr>
                <th>Paciente</th>
                <th>Fecha</th>
                <th>Hora</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody id="table-body">
            <!-- Las filas de las citas se agregarán aquí con JavaScript -->
            <tr>
                <td>Ejemplo: Carlos Mendoza</td>
                <td>2026-06-25</td>
                <td>10:00 AM</td>
                <td><button class="delete-btn">Cancelar</button></td>
            </tr>
        </tbody>
    </table>
</section>

    </main>
</body>
<script src="js/app.js"></script>

</html>
